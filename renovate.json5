{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "description": "Automates builder.toml version updates (CNB lifecycle + all pinned Paketo buildpacks) that Dependabot cannot track. All other ecosystems (GitHub Actions, Docker, npm, Go, Maven) are handled by .github/dependabot.yml.",
  "enabledManagers": ["custom.regex"],
  "labels": ["dependencies", "renovate"],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "groupName": "builder.toml versions",
      "schedule": ["before 7am on Monday"],
      "commitMessagePrefix": "chore(deps):"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "CNB lifecycle version in [lifecycle] section of builder.toml. Release tags on GitHub use a 'v' prefix (v0.21.7) which extractVersionTemplate strips so the stored value (0.21.7) matches correctly.",
      "managerFilePatterns": [
        "/^builder\.toml$/"
      ],
      "matchStrings": [
        "(?m)\\[lifecycle\\]\\s*\\n\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "buildpacks/lifecycle",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v?(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Pinned Paketo buildpack URI versions in [[buildpacks]] sections (e.g. docker://docker.io/paketobuildpacks/java:21.4.0). Every buildpack is pinned to a specific semver tag so Renovate can track updates.",
      "managerFilePatterns": [
        "/^builder\.toml$/"
      ],
      "matchStrings": [
        "uri\\s*=\\s*\"docker://docker\\.io/(?<depName>[^:\"]+):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Buildpack versions in [[order.group]] sections – must stay in sync with the [[buildpacks]] uri tags above. Uses a generic pattern to match all buildpacks. Renovate groups these into the same PR via the 'builder.toml versions' packageRule.",
      "managerFilePatterns": [
        "/^builder\.toml$/"
      ],
      "matchStrings": [
        "id\\s*=\\s*\"paketo-buildpacks/(?<depName>[^\"]+)\"\\s*\\n\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "paketobuildpacks/{{{depName}}}",
      "datasourceTemplate": "docker"
    }
  ]
}
